# TYPO3 Demo Environment
COMPOSE_PROJECT_NAME=typo3-demo

# Domain (used by Caddy for auto-HTTPS, use localhost for local dev)
TYPO3_DOMAIN=localhost

# Database
MARIADB_ROOT_PASSWORD=CHANGE_ME
MARIADB_DATABASE=typo3
MARIADB_USER=typo3
MARIADB_PASSWORD=CHANGE_ME

# TYPO3
TYPO3_CONTEXT=Development/Docker

# Ports (override if host ports are taken)
# CADDY_HTTP_PORT=8080
# CADDY_HTTPS_PORT=8443

# Dev mode (make dev)
# DB_PORT=3306
# XDEBUG_MODE=debug,develop

# Hetzner (deploy only)
# HETZNER_SSH_HOST=
# HETZNER_SSH_USER=deploy
