# TYPO3 Demo Environment
COMPOSE_PROJECT_NAME=typo3-demo

# Domain (used by Caddy for auto-HTTPS, use localhost for local dev)
TYPO3_DOMAIN=localhost
TYPO3_BASE_URL=https://localhost

# Database
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=typo3
MARIADB_USER=typo3
MARIADB_PASSWORD=typo3

# TYPO3
TYPO3_CONTEXT=Development/Docker
TYPO3_SETUP_ADMIN_USERNAME=admin
TYPO3_SETUP_ADMIN_PASSWORD=changeme!2026
TYPO3_BACKEND_PATH=typo3manage
TYPO3_SERVER_TYPE=apache

# Hetzner (deploy only)
# HETZNER_SSH_HOST=
# HETZNER_SSH_USER=deploy
