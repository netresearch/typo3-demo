# direnv configuration for typo3-demo
# Loads .env automatically and checks tool availability

dotenv_if_exists .env

# Ensure required tools
has docker || log_error "docker not found"
has git-lfs || log_error "git-lfs not found — run: git lfs install"

# Set compose project name
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-typo3-demo}"
